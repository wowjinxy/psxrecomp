# BIOS ROM (copyrighted, not distributable)
bios/

# DuckStation — upstream source is a git submodule pointing at stenzek/duckstation.
# Our custom changes live in tools/duckstation/psxrecomp_oracle.patch (committed).
# Only the build artefacts and prebuilt binary deps are untracked at the parent level;
# the submodule's own .gitignore handles in-tree ignores.
duckstation/build/
duckstation/dep/prebuilt/

# Ghidra project files (large, regenerable)
ghidra/

# Backup of the working state — see CURRENT_STATE.md for what this contains.
.happypath/

# Build artifacts
recompiler/build/
recompiler/build-asan/
recompiler/build-asan2/
recompiler/build-checked/
runtime/build/
runtime/build-msvc/
test_msvc/

# Recompiler output (derivative of copyrighted Sony BIOS, regenerate locally)
generated/

# Release packaging artifacts
release-stage/
*.zip

# Vendored upstream sources (cloned locally, not checked in)
beetle-psx/

# Prebuilt SDL2 / dep zips (large, regenerable)
sdl2-dev.zip
sdl2-msvc/

# Diagnostic dumps & smoke logs (transient)
*.log
*.jsonl

# Runtime diagnostic/crash files
psx_crash.txt
psx_diag.txt
psx_dispatch_misses.txt
psx_err.txt
psx_out.txt

# Probe / scratch artifacts
# All ad-hoc diagnostic dumps land under probes/ so the repo root stays clean.
# Runtime data (memcards) is intentionally NOT covered: card*.mcd, dummy.*.mcr.
probes/

# Ad-hoc scratch tools (underscore prefix convention).
# Real tools have no leading underscore (e.g. tools/codegen_audit.py).
tools/_*.py
/*.json
/*.png
/*.bmp
/*.txt

# OS / editor junk
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# Python caches
__pycache__/
